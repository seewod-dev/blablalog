const { SignJWT, importPKCS8 } = require("jose");

const YourPrivateKey = `
-----BEGIN PRIVATE KEY-----
MC4CAQAwBQYDK2VwBCIEIHQxKcVVjMAk16kpSg3PKk+gbM1RNpCJqnpjB0OBCFTL
-----END PRIVATE KEY-----
`.trim();

async function getToken_hefeng() {
    let privateKey = await importPKCS8(YourPrivateKey, 'EdDSA');

    const customHeader = {
        alg: 'EdDSA',
        kid: 'K6B8DPJHCB'
    };
    const iat = Math.floor(Date.now() / 1000) - 30;
    const exp = iat + 900;
    const customPayload = {
        sub: '2BKUGJNR7W',
        iat: iat,
        exp: exp
    };

    let token_hefeng = await new SignJWT(customPayload)
        .setProtectedHeader(customHeader)
        .sign(privateKey);
    return token_hefeng;
}

module.exports = { getToken_hefeng };